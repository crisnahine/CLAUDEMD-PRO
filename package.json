{
  "name": "claudemd-pro",
  "version": "0.4.2",
  "description": "Deep codebase-aware CLAUDE.md generator, linter, and effectiveness scorer",
  "type": "module",
  "bin": {
    "claudemd": "dist/cli/index.js"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsup src/cli/index.ts src/mcp/index.ts src/github-action/action.ts --format esm --dts --clean",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "claude-md",
    "ai",
    "linter",
    "generator",
    "mcp",
    "developer-tools"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "cosmiconfig": "^9.0.0",
    "glob": "^13.0.6",
    "handlebars": "^4.7.8",
    "ora": "^8.1.0",
    "remark-parse": "^11.0.0",
    "tiktoken": "^1.0.18",
    "unified": "^11.0.5",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ]
}
